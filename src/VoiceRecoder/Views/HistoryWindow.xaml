<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoiceRecoder.Views.HistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceRecoder.Views"
    Title="历史记录">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="12">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="选择日期" />
            <CalendarDatePicker
                x:Name="DatePicker"
                HorizontalAlignment="Stretch"
                DateChanged="DatePicker_DateChanged"
                PlaceholderText="选择日期" />
            <TextBlock
                Margin="0,8,0,0"
                FontSize="16"
                FontWeight="SemiBold"
                Text="有记录的日期" />
            <ListView
                x:Name="DatesListView"
                MaxHeight="320"
                SelectionChanged="DatesListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <Grid Grid.Column="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="SelectedDateText"
                FontSize="18"
                FontWeight="SemiBold"
                Text="记录详情" />

            <ListView
                x:Name="EntriesListView"
                Grid.Row="1"
                IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:HistoryEntryItem">
                        <Grid
                            Margin="0,8"
                            DoubleTapped="EntryItem_DoubleTapped"
                            PointerEntered="EntryItem_PointerEntered"
                            PointerExited="EntryItem_PointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind TimestampText}" />
                                <TextBlock
                                    Text="{x:Bind Text}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button
                                x:Name="DeleteButton"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Top"
                                Click="DeleteEntryButton_Click"
                                Style="{StaticResource SubtleButtonStyle}"
                                Tag="{x:Bind}"
                                ToolTipService.ToolTip="删除"
                                Visibility="Collapsed">
                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                x:Name="EmptyText"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="该日期暂无记录"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
