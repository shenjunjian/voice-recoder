<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon">

    <XamlUICommand x:Key="ExitApplicationCommand" Label="退出" />

    <tb:TaskbarIcon
        x:Key="TrayIcon"
        IconSource="Assets/TrayIcon.ico"
        ToolTipText="语音日志">
        <tb:TaskbarIcon.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem IsEnabled="False" Text="开始录制" />
                <MenuFlyoutItem IsEnabled="False" Text="查看记录" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Command="{StaticResource ExitApplicationCommand}" Text="退出" />
            </MenuFlyout>
        </tb:TaskbarIcon.ContextFlyout>
    </tb:TaskbarIcon>
</ResourceDictionary>
