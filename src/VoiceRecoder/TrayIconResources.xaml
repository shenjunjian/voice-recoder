<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon">

    <XamlUICommand x:Key="StartRecordingCommand" Label="开始录制" />
    <XamlUICommand x:Key="OpenRecordingWindowCommand" Label="打开录制窗口" />
    <XamlUICommand x:Key="ViewHistoryCommand" Label="查看记录" />
    <XamlUICommand x:Key="OpenSettingsCommand" Label="设置" />
    <XamlUICommand x:Key="ExitApplicationCommand" Label="退出" />

    <tb:TaskbarIcon
        x:Key="TrayIcon"
        IconSource="Assets/TrayIcon.ico"
        ToolTipText="语音日志" />
</ResourceDictionary>
